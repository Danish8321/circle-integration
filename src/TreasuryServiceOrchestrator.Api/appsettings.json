{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "TreasuryServiceOrchestrator": "Server=(localdb)\\mssqllocaldb;Database=TreasuryServiceOrchestrator;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Circle": {
    "BaseUrl": "https://api-sandbox.circle.com/",
    "ApiKey": ""
  },
  "CircleClient": {
    "TimeoutSeconds": 10,
    "RetryCount": 3,
    "CircuitBreakerFailureThreshold": 5,
    "CircuitBreakerDurationOfBreak": "00:00:30"
  },
  "CallerIdentity": {
    "AdminCallerId": "apiso-admin"
  },
  "MockMode": {
    "Enabled": false
  },
  "SupportedChains": {
    "Chains": ["ETH"]
  },
  "Reconciliation": {
    "IntervalSeconds": 300,
    "LookbackWindowMinutes": 1440
  },
  "BalanceSnapshot": {
    "IntervalSeconds": 3600
  }
}
